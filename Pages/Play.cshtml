@page
@model SseDemo.Pages.PlayModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover" />
    <title>Play</title>
</head>
<body style="margin:0;padding:0;background:#f9fafb;">

<style>
    /* ── Full-height flex layout ─────────────────────────── */
    .play-wrap {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 100svh;
        gap: 1.5rem;
        padding: 1rem 0;
        touch-action: none;
        user-select: none;
        -webkit-user-select: none;
    }

    /* ── Waiting state ───────────────────────────────────── */
    .spawn-hero {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.75rem;
        text-align: center;
        padding: 0 1rem;
    }
    .spawn-icon { font-size: 5rem; line-height: 1; animation: float 3s ease-in-out infinite; }
    @@keyframes float {
        0%, 100% { transform: translateY(0); }
        50%       { transform: translateY(-12px); }
    }
    .spawn-title { font-size: 1.6rem; font-weight: 800; color: #1e1b4b; margin: 0; }
    .spawn-sub   { color: #6b7280; font-size: 0.95rem; max-width: 280px; }

    .spawn-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background: linear-gradient(135deg, #6366f1, #8b5cf6);
        color: #fff;
        border: none;
        border-radius: 16px;
        font-size: 1.2rem;
        font-weight: 700;
        padding: 1rem 2rem;
        cursor: pointer;
        box-shadow: 0 6px 24px rgba(99,102,241,.4);
        transition: transform 0.12s, box-shadow 0.12s;
        -webkit-tap-highlight-color: transparent;
    }
    .spawn-btn:active { transform: scale(0.95); box-shadow: 0 2px 10px rgba(99,102,241,.3); }

    /* ── Playing state ───────────────────────────────────── */
    #state-playing { display: none; flex-direction: column; align-items: center; gap: 1.25rem; }

    .player-badge {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        background: #f5f3ff;
        border: 1.5px solid #ddd6fe;
        border-radius: 16px;
        padding: 0.6rem 1.2rem;
    }
    .player-emoji { font-size: 2.4rem; line-height: 1; }
    .player-label { font-size: 0.75rem; color: #7c3aed; font-weight: 600; text-transform: uppercase; letter-spacing: .05em; }
    .player-name  { font-size: 1.1rem; font-weight: 700; color: #1e1b4b; }

    /* ── D-Pad ───────────────────────────────────────────── */
    .dpad-large {
        display: grid;
        grid-template-columns: repeat(3, var(--btn-sz, 82px));
        grid-template-rows:    repeat(3, var(--btn-sz, 82px));
        gap: 10px;
    }
    @@media (max-width: 360px) {
        .dpad-large { --btn-sz: 70px; gap: 7px; }
    }

    .arrow-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 18px;
        border: 2px solid #c4b5fd;
        background: linear-gradient(145deg, #ede9fe, #ddd6fe);
        font-size: 2rem;
        color: #4c1d95;
        cursor: pointer;
        -webkit-tap-highlight-color: transparent;
        user-select: none;
        -webkit-user-select: none;
        transition: background 0.08s, transform 0.06s, box-shadow 0.08s;
        box-shadow: 0 4px 12px rgba(99,102,241,.2), inset 0 1px 0 rgba(255,255,255,.6);
    }
    .arrow-btn:active,
    .arrow-btn.pressing {
        background: linear-gradient(145deg, #7c3aed, #6d28d9);
        color: #fff;
        border-color: #7c3aed;
        transform: scale(0.92);
        box-shadow: 0 2px 6px rgba(99,102,241,.3);
    }
    /* invisible spacers */
    .dpad-large .gap { visibility: hidden; }

    /* ── Leave button ────────────────────────────────────── */
    .leave-btn {
        background: none;
        border: 1.5px solid #e5e7eb;
        color: #6b7280;
        border-radius: 10px;
        padding: 0.5rem 1.2rem;
        font-size: 0.9rem;
        cursor: pointer;
        transition: background 0.12s, color 0.12s;
        -webkit-tap-highlight-color: transparent;
    }
    .leave-btn:active { background: #fee2e2; color: #991b1b; border-color: #fca5a5; }
</style>

<div class="play-wrap">

    <!-- WAITING -->
    <div id="state-waiting">
        <div class="spawn-hero">
            <div class="spawn-icon">🎮</div>
            <p class="spawn-title">Ready to play?</p>
            <p class="spawn-sub">Spawn your object on the shared canvas and steer it with the arrow buttons.</p>
            <button class="spawn-btn" id="spawn-btn" onclick="spawn()">
                ✨ Spawn Object
            </button>
        </div>
    </div>

    <!-- PLAYING -->
    <div id="state-playing">
        <div class="player-badge">
            <div class="player-emoji" id="player-emoji">🚀</div>
            <div>
                <div class="player-label">You are</div>
                <div class="player-name" id="player-name">Rocket</div>
            </div>
        </div>

        <div class="dpad-large">
            <div class="gap"></div>
            <button class="arrow-btn" data-dir="up">↑</button>
            <div class="gap"></div>

            <button class="arrow-btn" data-dir="left">←</button>
            <div class="gap"></div>
            <button class="arrow-btn" data-dir="right">→</button>

            <div class="gap"></div>
            <button class="arrow-btn" data-dir="down">↓</button>
            <div class="gap"></div>
        </div>

        <button class="leave-btn" onclick="leave()">🚪 Leave game</button>
    </div>

</div>

<script>
const TYPE_NAMES = {
    '🚀':'Rocket','✈️':'Plane','🪐':'Planet','⭐':'Star',
    '🛸':'UFO','🐉':'Dragon','🦄':'Unicorn','🔥':'Fire',
    '💎':'Diamond','🎯':'Target','🐸':'Frog','🦋':'Butterfly',
    '🤖':'Robot','👾':'Alien','🌈':'Rainbow','🐋':'Whale',
    '🦊':'Fox','🧨':'Firecracker','🎪':'Circus','🌋':'Volcano',
    '🦅':'Eagle','🐙':'Octopus','🧊':'Ice','🌊':'Wave',
    '🎸':'Guitar','🏆':'Trophy','🦁':'Lion','🐺':'Wolf','🌙':'Moon'
};

// ── State ─────────────────────────────────────────────────
let objId   = null;
let objType = null;

function showWaiting() {
    document.getElementById('state-waiting').style.display = '';
    document.getElementById('state-playing').style.display = 'none';
    document.getElementById('spawn-btn').disabled = false;
}

function showPlaying(id, type) {
    objId   = id;
    objType = type;
    document.getElementById('player-emoji').textContent = type;
    document.getElementById('player-name').textContent  = TYPE_NAMES[type] ?? type;
    document.getElementById('state-waiting').style.display = 'none';
    document.getElementById('state-playing').style.display = 'flex';
    sessionStorage.setItem('playObjId',   id);
    sessionStorage.setItem('playObjType', type);
}

// ── Restore session ───────────────────────────────────────
async function tryRestore() {
    const id   = sessionStorage.getItem('playObjId');
    const type = sessionStorage.getItem('playObjType');
    if (!id || !type) return;
    try {
        const res  = await fetch('/api/state');
        const list = await res.json();
        if (list.some(o => o.id === id)) { showPlaying(id, type); return; }
    } catch { /* ignore */ }
    sessionStorage.removeItem('playObjId');
    sessionStorage.removeItem('playObjType');
}

// ── Spawn ─────────────────────────────────────────────────
async function spawn() {
    const btn = document.getElementById('spawn-btn');
    btn.disabled = true;
    try {
        const res = await fetch('/api/spawn', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: '{}' });
        if (!res.ok) throw new Error();
        const obj = await res.json();
        showPlaying(obj.id, obj.type);
    } catch {
        btn.disabled = false;
    }
}

// ── Movement ──────────────────────────────────────────────
let repeatTimer = null;

function startMove(dir, btn) {
    clearInterval(repeatTimer);
    repeatTimer = null;
    btn.classList.add('pressing');
    doMove(dir);
    repeatTimer = setInterval(() => doMove(dir), 140);
}

function stopMove(btn) {
    btn?.classList.remove('pressing');
    clearInterval(repeatTimer);
    repeatTimer = null;
}

function doMove(dir) {
    if (!objId) return;
    fetch('/api/move', {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify({ id: objId, direction: dir })
    }).then(res => {
        if (res.status === 404) leave(); // object gone (server reset)
    }).catch(() => {});
}

// ── Leave
async function leave() {
    const id = objId;
    sessionStorage.removeItem('playObjId');
    sessionStorage.removeItem('playObjType');
    objId = objType = null;
    showWaiting();
    if (id) {
        try { await fetch(`/api/objects/${id}`, { method: 'DELETE' }); } catch { /* ignore */ }
    }
}

// ── D-Pad binding ─────────────────────────────────────────
document.querySelectorAll('.arrow-btn').forEach(btn => {
    const dir = btn.dataset.dir;

    btn.addEventListener('pointerdown', e => {
        e.preventDefault();
        btn.setPointerCapture(e.pointerId);
        startMove(dir, btn);
    }, { passive: false });

    const end = () => stopMove(btn);
    btn.addEventListener('pointerup',     end);
    btn.addEventListener('pointercancel', end);
    btn.addEventListener('contextmenu',   e => e.preventDefault());
});

// Keyboard arrows (nice for testing on desktop)
document.addEventListener('keydown', e => {
    const map = { ArrowUp:'up', ArrowDown:'down', ArrowLeft:'left', ArrowRight:'right' };
    if (!map[e.key] || !objId) return;
    e.preventDefault();
    if (!repeatTimer) startMove(map[e.key], null);
});
document.addEventListener('keyup', e => {
    if (['ArrowUp','ArrowDown','ArrowLeft','ArrowRight'].includes(e.key)) stopMove(null);
});

// ── Boot ─────────────────────────────────────────────────
tryRestore();
</script>
</body>
</html>
