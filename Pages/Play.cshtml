@page
@model SseDemo.Pages.PlayModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover" />
    <title>Play</title>
</head>
<body style="margin:0;padding:0;background:#f9fafb;">

<style>
    /* ── Full-height flex layout ─────────────────────────── */
    .play-wrap {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 100svh;
        gap: 1.5rem;
        padding: 1rem 0;
        touch-action: none;
        user-select: none;
        -webkit-user-select: none;
    }

    /* ── Waiting state ───────────────────────────────────── */
    .spawn-hero {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.75rem;
        text-align: center;
        padding: 0 1rem;
    }
    .spawn-icon { font-size: 5rem; line-height: 1; animation: float 3s ease-in-out infinite; }
    @@keyframes float {
        0%, 100% { transform: translateY(0); }
        50%       { transform: translateY(-12px); }
    }
    .spawn-title { font-size: 1.6rem; font-weight: 800; color: #1e1b4b; margin: 0; }
    .spawn-sub   { color: #6b7280; font-size: 0.95rem; max-width: 280px; }

    .spawn-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background: linear-gradient(135deg, #6366f1, #8b5cf6);
        color: #fff;
        border: none;
        border-radius: 16px;
        font-size: 1.2rem;
        font-weight: 700;
        padding: 1rem 2rem;
        cursor: pointer;
        box-shadow: 0 6px 24px rgba(99,102,241,.4);
        transition: transform 0.12s, box-shadow 0.12s;
        -webkit-tap-highlight-color: transparent;
    }
    .spawn-btn:active { transform: scale(0.95); box-shadow: 0 2px 10px rgba(99,102,241,.3); }

    /* ── Playing state ───────────────────────────────────── */
    #state-playing { display: none; flex-direction: column; align-items: center; gap: 1.25rem; }

    .player-badge {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        background: #f5f3ff;
        border: 1.5px solid #ddd6fe;
        border-radius: 16px;
        padding: 0.6rem 1.2rem;
    }
    .player-emoji { font-size: 2.4rem; line-height: 1; }
    .player-label { font-size: 0.75rem; color: #7c3aed; font-weight: 600; text-transform: uppercase; letter-spacing: .05em; }
    .player-name  { font-size: 1.1rem; font-weight: 700; color: #1e1b4b; }

    /* ── D-Pad (fine pointer: mouse/trackpad) ───────────── */
    .dpad-large {
        display: grid;
        grid-template-columns: repeat(3, var(--btn-sz, 82px));
        grid-template-rows:    repeat(3, var(--btn-sz, 82px));
        gap: 10px;
    }
    .arrow-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 18px;
        border: 2px solid #c4b5fd;
        background: linear-gradient(145deg, #ede9fe, #ddd6fe);
        font-size: 2rem;
        color: #4c1d95;
        cursor: pointer;
        -webkit-tap-highlight-color: transparent;
        transition: background 0.08s, transform 0.06s, box-shadow 0.08s;
        box-shadow: 0 4px 12px rgba(99,102,241,.2), inset 0 1px 0 rgba(255,255,255,.6);
    }
    .arrow-btn:active,
    .arrow-btn.pressing {
        background: linear-gradient(145deg, #7c3aed, #6d28d9);
        color: #fff;
        border-color: #7c3aed;
        transform: scale(0.92);
        box-shadow: 0 2px 6px rgba(99,102,241,.3);
    }
    .dpad-large .gap { visibility: hidden; }

    /* ── Joystick (coarse pointer: touch) ────────────────── */
    .joystick-base {
        position: relative;
        width: 200px;
        height: 200px;
        border-radius: 50%;
        background: rgba(99, 102, 241, 0.1);
        border: 2px solid #c4b5fd;
        box-shadow: 0 4px 24px rgba(99,102,241,.2), inset 0 1px 0 rgba(255,255,255,.5);
        touch-action: none;
        cursor: grab;
    }
    .joystick-base:active { cursor: grabbing; }

    .joystick-thumb {
        position: absolute;
        width: 76px;
        height: 76px;
        border-radius: 50%;
        background: linear-gradient(145deg, #6366f1, #7c3aed);
        box-shadow: 0 4px 18px rgba(99,102,241,.5), inset 0 1px 0 rgba(255,255,255,.3);
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        pointer-events: none;
        transition: transform 0.18s cubic-bezier(.22,1,.36,1);
        will-change: transform;
    }
    .joystick-thumb.active { transition: none; }

    /* direction hint arrows on base */
    .joystick-hints {
        position: absolute;
        inset: 0;
        pointer-events: none;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
        color: rgba(99,102,241,.35);
    }
    .joystick-hints span {
        position: absolute;
    }
    .joystick-hints .h-up         { top: 10px;    left: 50%; transform: translateX(-50%); }
    .joystick-hints .h-down       { bottom: 10px; left: 50%; transform: translateX(-50%); }
    .joystick-hints .h-left       { left: 10px;   top: 50%;  transform: translateY(-50%); }
    .joystick-hints .h-right      { right: 10px;  top: 50%;  transform: translateY(-50%); }
    .joystick-hints .h-up-left    { top: 14px;    left: 14px; }
    .joystick-hints .h-up-right   { top: 14px;    right: 14px; }
    .joystick-hints .h-down-left  { bottom: 14px; left: 14px; }
    .joystick-hints .h-down-right { bottom: 14px; right: 14px; }

    /* ── Leave button ────────────────────────────────────── */
    .leave-btn {
        background: none;
        border: 1.5px solid #e5e7eb;
        color: #6b7280;
        border-radius: 10px;
        padding: 0.5rem 1.2rem;
        font-size: 0.9rem;
        cursor: pointer;
        transition: background 0.12s, color 0.12s;
        -webkit-tap-highlight-color: transparent;
    }
    .leave-btn:active { background: #fee2e2; color: #991b1b; border-color: #fca5a5; }

    /* ── Show/hide controls by pointer type ─────────────── */
    @@media (pointer: fine)   { .joystick-base { display: none; } }
    @@media (pointer: coarse) { .dpad-large    { display: none; } }
</style>

<div class="play-wrap">

    <!-- WAITING -->
    <div id="state-waiting">
        <div class="spawn-hero">
            <div class="spawn-icon">🎮</div>
            <p class="spawn-title">Ready to play?</p>
            <p class="spawn-sub">Spawn your object on the shared canvas and steer it with the arrow buttons.</p>
            <button class="spawn-btn" id="spawn-btn" onclick="spawn()">
                ✨ Spawn Object
            </button>
        </div>
    </div>

    <!-- PLAYING -->
    <div id="state-playing">
        <div class="player-badge">
            <div class="player-emoji" id="player-emoji">🚀</div>
            <div>
                <div class="player-label">You are</div>
                <div class="player-name" id="player-name">Rocket</div>
            </div>
        </div>

        <div class="dpad-large">
            <div class="gap"></div>
            <button class="arrow-btn" data-dir="up">↑</button>
            <div class="gap"></div>

            <button class="arrow-btn" data-dir="left">←</button>
            <div class="gap"></div>
            <button class="arrow-btn" data-dir="right">→</button>

            <div class="gap"></div>
            <button class="arrow-btn" data-dir="down">↓</button>
            <div class="gap"></div>
        </div>

        <div class="joystick-base" id="joystick-base">
            <div class="joystick-hints">
                <span class="h-up">↑</span>
                <span class="h-down">↓</span>
                <span class="h-left">←</span>
                <span class="h-right">→</span>
                <span class="h-up-left">↖</span>
                <span class="h-up-right">↗</span>
                <span class="h-down-left">↙</span>
                <span class="h-down-right">↘</span>
            </div>
            <div class="joystick-thumb" id="joystick-thumb"></div>
        </div>

        <button class="leave-btn" onclick="leave()">🚪 Leave game</button>
    </div>

</div>

<script>
const TYPE_NAMES = {
    '🚀':'Rocket','✈️':'Plane','🪐':'Planet','⭐':'Star',
    '🛸':'UFO','🐉':'Dragon','🦄':'Unicorn','🔥':'Fire',
    '💎':'Diamond','🎯':'Target','🐸':'Frog','🦋':'Butterfly',
    '🤖':'Robot','👾':'Alien','🌈':'Rainbow','🐋':'Whale',
    '🦊':'Fox','🧨':'Firecracker','🎪':'Circus','🌋':'Volcano',
    '🦅':'Eagle','🐙':'Octopus','🧊':'Ice','🌊':'Wave',
    '🎸':'Guitar','🏆':'Trophy','🦁':'Lion','🐺':'Wolf','🌙':'Moon'
};

// ── State ─────────────────────────────────────────────────
let objId   = null;
let objType = null;

function showWaiting() {
    document.getElementById('state-waiting').style.display = '';
    document.getElementById('state-playing').style.display = 'none';
    document.getElementById('spawn-btn').disabled = false;
}

function showPlaying(id, type) {
    objId   = id;
    objType = type;
    document.getElementById('player-emoji').textContent = type;
    document.getElementById('player-name').textContent  = TYPE_NAMES[type] ?? type;
    document.getElementById('state-waiting').style.display = 'none';
    document.getElementById('state-playing').style.display = 'flex';
    sessionStorage.setItem('playObjId',   id);
    sessionStorage.setItem('playObjType', type);
}

// ── Restore session ───────────────────────────────────────
async function tryRestore() {
    const id   = sessionStorage.getItem('playObjId');
    const type = sessionStorage.getItem('playObjType');
    if (!id || !type) return;
    try {
        const res  = await fetch('/api/state');
        const list = await res.json();
        if (list.some(o => o.id === id)) { showPlaying(id, type); return; }
    } catch { /* ignore */ }
    sessionStorage.removeItem('playObjId');
    sessionStorage.removeItem('playObjType');
}

// ── Spawn ─────────────────────────────────────────────────
async function spawn() {
    const btn = document.getElementById('spawn-btn');
    btn.disabled = true;
    try {
        const res = await fetch('/api/spawn', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: '{}' });
        if (!res.ok) throw new Error();
        const obj = await res.json();
        showPlaying(obj.id, obj.type);
    } catch {
        btn.disabled = false;
    }
}

// ── Movement ──────────────────────────────────────────────
let repeatTimer = null;

function startMove(dir) {
    clearInterval(repeatTimer);
    repeatTimer = null;
    doMove(dir);
    repeatTimer = setInterval(() => doMove(dir), 140);
}

function stopMove() {
    clearInterval(repeatTimer);
    repeatTimer = null;
}

function doMove(dir) {
    if (!objId) return;
    fetch('/api/move', {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify({ id: objId, direction: dir })
    }).then(res => {
        if (res.status === 404) leave(); // object gone (server reset)
    }).catch(() => {});
}

// ── Leave
async function leave() {
    const id = objId;
    sessionStorage.removeItem('playObjId');
    sessionStorage.removeItem('playObjType');
    objId = objType = null;
    showWaiting();
    if (id) {
        try { await fetch(`/api/objects/${id}`, { method: 'DELETE' }); } catch { /* ignore */ }
    }
}

// ── D-Pad binding (fine pointer) ──────────────────────────
document.querySelectorAll('.arrow-btn').forEach(btn => {
    const dir = btn.dataset.dir;
    btn.addEventListener('pointerdown', e => {
        e.preventDefault();
        btn.setPointerCapture(e.pointerId);
        btn.classList.add('pressing');
        startMove(dir);
    }, { passive: false });
    const end = () => { btn.classList.remove('pressing'); stopMove(); };
    btn.addEventListener('pointerup',     end);
    btn.addEventListener('pointercancel', end);
    btn.addEventListener('contextmenu',   e => e.preventDefault());
});

// ── Joystick ──────────────────────────────────────────────
const joystickBase  = document.getElementById('joystick-base');
const joystickThumb = document.getElementById('joystick-thumb');
const DEAD_ZONE  = 18;   // px — inner circle with no movement
const MAX_TRAVEL = 62;   // px — thumb clamped to this radius

let joystickDir = null;

function joystickDirection(dx, dy) {
    const angle = ((Math.atan2(dy, dx) * 180 / Math.PI) + 360) % 360;
    if (angle < 22.5  || angle >= 337.5) return 'right';
    if (angle < 67.5)                    return 'down-right';
    if (angle < 112.5)                   return 'down';
    if (angle < 157.5)                   return 'down-left';
    if (angle < 202.5)                   return 'left';
    if (angle < 247.5)                   return 'up-left';
    if (angle < 292.5)                   return 'up';
    return 'up-right';
}

function setThumb(dx, dy, dist) {
    const clamped = Math.min(dist, MAX_TRAVEL);
    const angle   = Math.atan2(dy, dx);
    const tx = Math.cos(angle) * clamped;
    const ty = Math.sin(angle) * clamped;
    joystickThumb.style.transform = `translate(calc(-50% + ${tx}px), calc(-50% + ${ty}px))`;
}

joystickBase.addEventListener('pointerdown', e => {
    e.preventDefault();
    joystickBase.setPointerCapture(e.pointerId);
    joystickThumb.classList.add('active');
}, { passive: false });

joystickBase.addEventListener('pointermove', e => {
    if (!joystickBase.hasPointerCapture(e.pointerId) || !objId) return;
    const rect = joystickBase.getBoundingClientRect();
    const dx   = e.clientX - (rect.left + rect.width  / 2);
    const dy   = e.clientY - (rect.top  + rect.height / 2);
    const dist = Math.hypot(dx, dy);

    setThumb(dx, dy, dist);

    if (dist < DEAD_ZONE) {
        if (joystickDir !== null) { joystickDir = null; stopMove(); }
        return;
    }

    const dir = joystickDirection(dx, dy);
    if (dir !== joystickDir) {
        joystickDir = dir;
        startMove(dir);
    }
});

function resetJoystick() {
    joystickDir = null;
    stopMove();
    joystickThumb.classList.remove('active');
    joystickThumb.style.transform = 'translate(-50%, -50%)';
}

joystickBase.addEventListener('pointerup',     resetJoystick);
joystickBase.addEventListener('pointercancel', resetJoystick);
joystickBase.addEventListener('contextmenu',   e => e.preventDefault());

// Keyboard arrows (desktop)
document.addEventListener('keydown', e => {
    const map = { ArrowUp:'up', ArrowDown:'down', ArrowLeft:'left', ArrowRight:'right' };
    if (!map[e.key] || !objId) return;
    e.preventDefault();
    if (!repeatTimer) startMove(map[e.key]);
});
document.addEventListener('keyup', e => {
    if (['ArrowUp','ArrowDown','ArrowLeft','ArrowRight'].includes(e.key)) stopMove();
});

// ── Boot ─────────────────────────────────────────────────
tryRestore();
</script>
</body>
</html>
