@page
@model SseDemo.Pages.MoverModel
@{
    ViewData["Title"] = "Rocket Mover";
}

<style>
    /* ── Connection status ───────────────────────────────── */
    #sse-status {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        font-size: 0.85rem;
        font-weight: 600;
        padding: 0.3rem 0.8rem;
        border-radius: 999px;
        margin-bottom: 0.75rem;
        transition: all 0.3s;
    }
    #sse-status.connecting { background: #fef3c7; color: #92400e; }
    #sse-status.connected  { background: #d1fae5; color: #065f46; }
    #sse-status.error      { background: #fee2e2; color: #991b1b; }
    .pulse {
        width: 8px; height: 8px; border-radius: 50%;
        animation: pulse 1.5s infinite;
    }
    .connecting .pulse { background: #f59e0b; }
    .connected  .pulse { background: #10b981; }
    .error      .pulse { background: #ef4444; animation: none; }
    @@keyframes pulse {
        0%, 100% { opacity: 1; transform: scale(1); }
        50%       { opacity: 0.5; transform: scale(1.4); }
    }

    /* ── Arena ───────────────────────────────────────────── */
    .arena-wrapper {
        position: relative;
        width: 100%;
        height: calc(100vh - 220px);
        min-height: 400px;
        border-radius: 12px;
        overflow: hidden;
        background-color: #0f172a;
        background-image:
            linear-gradient(rgba(99,102,241,.12) 1px, transparent 1px),
            linear-gradient(90deg, rgba(99,102,241,.12) 1px, transparent 1px);
        background-size: 40px 40px;
        box-shadow: inset 0 0 80px rgba(0,0,0,.6), 0 4px 24px rgba(0,0,0,.3);
    }

    /* Subtle corner stars */
    .arena-wrapper::before {
        content: '✦ ✧ ✦ ✧ ✦ ✧ ✦ ✧ ✦ ✧ ✦';
        position: absolute;
        top: 14px; left: 50%;
        transform: translateX(-50%);
        color: rgba(255,255,255,.08);
        font-size: 1.2rem;
        letter-spacing: 1.4rem;
        white-space: nowrap;
        pointer-events: none;
    }

    .arena-obj {
        position: absolute;
        width: 64px;
        height: 64px;
        border-radius: 50%;
        background: radial-gradient(circle at 38% 38%, rgba(255,255,255,.18), rgba(0,0,0,.25));
        border: 3px solid var(--c, #6366f1);
        box-shadow: 0 0 20px 6px var(--c, #6366f1), inset 0 0 16px rgba(255,255,255,.1);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        line-height: 1;
        transition: left .18s cubic-bezier(.25,.8,.25,1), top .18s cubic-bezier(.25,.8,.25,1);
        user-select: none;
    }
    .arena-obj.flash {
        box-shadow: 0 0 44px 16px var(--c, #6366f1), inset 0 0 28px rgba(255,255,255,.25) !important;
    }

    .arena-hint {
        position: absolute;
        bottom: 12px;
        left: 50%;
        transform: translateX(-50%);
        font-size: 0.75rem;
        color: rgba(255,255,255,.22);
        white-space: nowrap;
        pointer-events: none;
    }

    /* ── Meta bar ────────────────────────────────────────── */
    .meta-bar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-top: 0.6rem;
        font-size: 0.82rem;
        color: #6b7280;
    }
    .reset-btn {
        background: #fee2e2;
        color: #991b1b;
        border: 1px solid #fca5a5;
        border-radius: 6px;
        padding: 0.25rem 0.75rem;
        font-size: 0.8rem;
        cursor: pointer;
        transition: background 0.15s;
    }
    .reset-btn:hover { background: #fecaca; }
</style>

<div id="sse-status" class="connecting">
    <span class="pulse"></span>
    <span id="sse-status-text">Connecting…</span>
</div>

<div class="arena-wrapper" id="arena">
    <span class="arena-hint">Open the 🎮 Play page on your phone to join</span>
</div>

<div class="meta-bar">
    <span id="obj-count">No objects on canvas</span>
    <button class="reset-btn" onclick="resetAll()">🗑️ Reset All</button>
</div>

<script>
const OBJ_SIZE    = 64;
const GLOW_COLORS = ['#6366f1','#10b981','#f59e0b','#ef4444','#ec4899','#06b6d4','#8b5cf6','#84cc16',
                     '#f97316','#14b8a6','#e879f9','#fb7185','#38bdf8','#a3e635','#facc15','#64748b','#f43f5e','#22d3ee'];

const arena   = document.getElementById('arena');
const objects = {};   // { [id]: { obj, el } }
let   colorIdx = 0;

// ── Object rendering ──────────────────────────────────────
function addObject(data) {
    if (objects[data.id]) { updateObject(data); return; }
    const color = GLOW_COLORS[colorIdx++ % GLOW_COLORS.length];
    const el = document.createElement('div');
    el.className = 'arena-obj';
    el.style.setProperty('--c', color);
    el.textContent = data.type;
    el.style.left  = (data.px * (arena.clientWidth  - OBJ_SIZE)) + 'px';
    el.style.top   = (data.py * (arena.clientHeight - OBJ_SIZE)) + 'px';
    arena.appendChild(el);
    objects[data.id] = { obj: data, el };
    updateCount();
}

function updateObject(data) {
    const entry = objects[data.id];
    if (!entry) { addObject(data); return; }
    entry.obj = data;
    entry.el.style.left = (data.px * (arena.clientWidth  - OBJ_SIZE)) + 'px';
    entry.el.style.top  = (data.py * (arena.clientHeight - OBJ_SIZE)) + 'px';
    flashEl(entry.el);
}

function flashEl(el) {
    el.classList.remove('flash');
    void el.offsetWidth;
    el.classList.add('flash');
    setTimeout(() => el.classList.remove('flash'), 250);
}

function clearAllObjects() {
    Object.values(objects).forEach(e => e.el.remove());
    for (const k in objects) delete objects[k];
    colorIdx = 0;
    updateCount();
}

function removeObject(id) {
    const entry = objects[id];
    if (!entry) return;
    entry.el.remove();
    delete objects[id];
    updateCount();
}

function updateCount() {
    const n = Object.keys(objects).length;
    document.getElementById('obj-count').textContent =
        n === 0 ? 'No objects on canvas' : `${n} object${n !== 1 ? 's' : ''} on canvas`;
}

window.addEventListener('resize', () =>
    Object.values(objects).forEach(({ el, obj }) => {
        el.style.left = (obj.px * (arena.clientWidth  - OBJ_SIZE)) + 'px';
        el.style.top  = (obj.py * (arena.clientHeight - OBJ_SIZE)) + 'px';
    })
);

// ── Load existing state ───────────────────────────────────
async function loadState() {
    try {
        const list = await fetch('/api/state').then(r => r.json());
        list.forEach(addObject);
    } catch { /* ignore — SSE will keep us in sync */ }
}

// ── Reset ─────────────────────────────────────────────────
async function resetAll() {
    if (!confirm('Remove all objects from the canvas?')) return;
    await fetch('/api/objects', { method: 'DELETE' });
}

// ── SSE ──────────────────────────────────────────────────
const statusEl   = document.getElementById('sse-status');
const statusText = document.getElementById('sse-status-text');

function setStatus(state, text) {
    statusEl.className = state;
    statusText.textContent = text;
}

function connect() {
    setStatus('connecting', 'Connecting…');
    const es = new EventSource('/sse');
    es.addEventListener('connected', () => setStatus('connected', 'Connected — waiting for players'));
    es.addEventListener('spawn', e => addObject(JSON.parse(e.data)));
    es.addEventListener('move',    e => updateObject(JSON.parse(e.data)));
    es.addEventListener('despawn', e => removeObject(e.data));
    es.addEventListener('clear', () => clearAllObjects());
    es.onerror = () => setStatus('error', 'Connection lost — reconnecting…');
}

// ── Boot ─────────────────────────────────────────────────
loadState();
connect();
</script>
